MONGODB_URI=mongodb://USER:PASSWORD@YOUR_SERVER_IP:27017/
MONGODB_DB=smartdoor
AUTH_SECRET=run-`npx auth secret`-to-generate-one-for-real-use

# Web Push (alarm notifications) — generate your own with `npx web-push generate-vapid-keys`
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com

# Authenticates Vercel Cron's calls to /api/cron/check-offline (Vercel sends this
# automatically as a Bearer token when the env var is set — no extra config needed there).
# Optional locally; leave unset and the route skips the auth check.
CRON_SECRET=

# How long (ms) without a poll before a device is considered offline. Default 15000.
# The cron schedule in vercel.json (default: every minute) is the other half of this —
# edit its "schedule" field directly if you change this threshold significantly.
ONLINE_THRESHOLD_MS=
